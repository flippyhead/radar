{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/first-run.mjs\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PluginInstall": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/install.mjs\"",
            "timeout": 120000
          }
        ]
      }
    ]
  }
}
